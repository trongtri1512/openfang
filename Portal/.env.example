# BizClaw Portal Environment Variables
# Copy this file to .env and fill in your values.

# ─── Portal Configuration ─────────────────────────────────────────────
# Bind address (default: 0.0.0.0:4201)
# PORTAL_LISTEN=0.0.0.0:4201

# Portal admin password (for super-admin login)
# PORTAL_ADMIN_KEY=your-admin-password

# ─── Database ─────────────────────────────────────────────────────────
# PostgreSQL connection string (optional — falls back to JSON file)
# PORTAL_DATABASE_URL=postgres://portal:portal@portal-db:5432/portal

# Portal DB settings (for docker-compose)
PORTAL_DB_USER=portal
PORTAL_DB_PASSWORD=portal
PORTAL_DB_NAME=portal

# ─── OpenFang Connection ──────────────────────────────────────────────
# URL to reach OpenFang API (for system proxies: channels, providers, models, skills, hands)
# OPENFANG_API_URL=http://openfang:4200

# OpenFang API key (used as fallback admin key)
# OPENFANG_API_KEY=

# ─── Logging ──────────────────────────────────────────────────────────
# RUST_LOG=info
# RUST_LOG=portal=debug
